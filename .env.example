ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides:
# JARVIS_MODEL=claude-opus-4-8
# JARVIS_VOICE=Daniel
# Speech model dir under models/ (default: vosk-model-en-us-0.22-lgraph).
# Use vosk-model-en-us-0.22 for best accuracy (1.8 GB), or the small model for speed.
# JARVIS_VOSK_MODEL=vosk-model-en-us-0.22-lgraph
# Microphone input device id (see the "Input devices" list logged at startup).
# Default is the system default mic; set this to pin a specific, clearer mic.
# JARVIS_MIC_DEVICE=21
# Where Jarvis stores conversation + long-term memory. By default it auto-detects
# Google Drive and uses "<Google Drive>/Jarvis" so memory syncs across computers;
# otherwise it falls back to the local app-data folder. Override the path here.
# JARVIS_MEMORY_DIR=G:\My Drive\Jarvis
#
# Zero-setup across machines: the first computer that has ANTHROPIC_API_KEY writes
# it (plus JARVIS_MODEL/JARVIS_VOICE) into "<memory dir>/jarvis-config.json". Other
# computers with that synced folder read the key automatically — no .env needed.
# A local .env always takes precedence over the shared file. The key is stored in
# plaintext in your Drive, so rotate it if that folder is ever exposed.
